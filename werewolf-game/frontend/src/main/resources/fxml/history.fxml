<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.werewolf.controller.HistoryController"
           fx:id="rootPane"
           styleClass="root-bg">

    <Region fx:id="bgImage" mouseTransparent="true"/>
    <Region styleClass="bg-overlay" mouseTransparent="true"/>

    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="topbar">
                <padding><Insets top="18" right="28" bottom="18" left="28"/></padding>
                <VBox>
                    <Label text="Historique" styleClass="title-l"/>
                    <Label text="Tes parties et le classement global" styleClass="muted"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="myStatsLabel" styleClass="badge"/>
                <Button fx:id="backBtn" text="← Retour" onAction="#onBack" styleClass="btn-ghost"/>
            </HBox>
        </top>

        <center>
            <HBox spacing="24">
                <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

                <VBox spacing="14" HBox.hgrow="ALWAYS" styleClass="card">
                    <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>
                    <Label text="Tes 50 dernières parties" styleClass="title-m"/>
                    <ListView fx:id="historyList" VBox.vgrow="ALWAYS" styleClass="dark-list logs"/>
                </VBox>

                <VBox spacing="14" prefWidth="480" styleClass="card">
                    <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>
                    <Label text="🏆  Top 50 ELO" styleClass="title-m"/>
                    <ListView fx:id="leaderboardList" VBox.vgrow="ALWAYS" styleClass="dark-list logs"/>
                </VBox>
            </HBox>
        </center>
    </BorderPane>
</StackPane>
