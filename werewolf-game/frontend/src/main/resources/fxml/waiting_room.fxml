<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.werewolf.controller.WaitingRoomController"
           fx:id="rootPane"
           styleClass="root-bg">

    <Region fx:id="bgImage" mouseTransparent="true"/>
    <Region styleClass="bg-overlay" mouseTransparent="true"/>

    <BorderPane>
        <top>
            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="topbar">
                <padding><Insets top="18" right="28" bottom="18" left="28"/></padding>
                <Label fx:id="gameLabel" styleClass="title-l"/>
                <Label text="En attente du démarrage" styleClass="muted"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="leaveBtn" text="Quitter" onAction="#onLeave" styleClass="btn-ghost"/>
            </HBox>
        </top>

        <center>
            <VBox alignment="CENTER" spacing="24" maxWidth="700" maxHeight="-Infinity" styleClass="card-glass">
                <padding><Insets top="40" right="50" bottom="40" left="50"/></padding>

                <Label text="🐺" style="-fx-font-size: 56px;"/>
                <Label text="Le village se rassemble" styleClass="title-l"/>
                <Label text="Patientez le temps que tous les villageois rejoignent la partie." styleClass="subtitle"/>

                <HBox alignment="CENTER" spacing="8">
                    <Label fx:id="countLabel" styleClass="badge badge-accent"/>
                    <Label text="·" styleClass="muted"/>
                    <Label text="4 minimum pour démarrer" styleClass="muted"/>
                </HBox>

                <ListView fx:id="playerList" prefHeight="340" maxWidth="Infinity" styleClass="dark-list"/>

                <Button fx:id="startBtn" text="Démarrer la partie" onAction="#onStart"
                        styleClass="btn-primary" maxWidth="Infinity"/>
                <Label fx:id="errorLabel" styleClass="error"/>
            </VBox>
        </center>
    </BorderPane>
</StackPane>
