<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.werewolf.controller.LoginController"
           fx:id="rootPane"
           styleClass="root-bg">

    <!-- Image atmosphérique en arrière-plan -->
    <Region fx:id="bgImage" mouseTransparent="true"/>

    <!-- Overlay sombre pour la lisibilité -->
    <Region styleClass="bg-overlay" mouseTransparent="true"/>

    <!-- Halo subtil derrière le card -->
    <Region styleClass="lantern-glow" StackPane.alignment="CENTER" mouseTransparent="true"/>

    <!-- Lune décorative discrète -->
    <Region fx:id="moonDeco" styleClass="moon" StackPane.alignment="TOP_CENTER" mouseTransparent="true">
        <StackPane.margin><Insets top="60"/></StackPane.margin>
    </Region>

    <!-- Card central glass -->
    <VBox alignment="CENTER" spacing="18" maxWidth="440" maxHeight="-Infinity" styleClass="card-glass">
        <padding><Insets top="44" right="48" bottom="44" left="48"/></padding>

        <Label text="LOUP·GAROU" styleClass="brand-title"/>
        <Label text="Connectez-vous pour rejoindre une partie" styleClass="subtitle"/>

        <Region prefHeight="8"/>

        <VBox spacing="10">
            <Label text="PSEUDO" styleClass="muted"/>
            <TextField fx:id="pseudoField" promptText="Votre pseudo ou pseudo#1234" styleClass="input"/>
        </VBox>

        <VBox spacing="10">
            <Label text="EMAIL  (inscription uniquement)" styleClass="muted"/>
            <TextField fx:id="emailField" promptText="vous@exemple.com" styleClass="input"/>
        </VBox>

        <VBox spacing="10">
            <Label text="MOT DE PASSE" styleClass="muted"/>
            <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="input"/>
        </VBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="AVATAR" styleClass="muted"/>
            <ComboBox fx:id="avatarCombo" prefWidth="100" styleClass="dark-combo"/>
        </HBox>

        <Region prefHeight="6"/>

        <Button fx:id="loginBtn" text="Se connecter" onAction="#onLogin" styleClass="btn-primary" maxWidth="Infinity"/>
        <Button fx:id="registerBtn" text="Créer un compte" onAction="#onRegister" styleClass="btn-ghost" maxWidth="Infinity"/>

        <Label fx:id="errorLabel" styleClass="error"/>
    </VBox>
</StackPane>
