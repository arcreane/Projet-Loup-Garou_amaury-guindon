<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.werewolf.controller.LoginController"
           fx:id="rootPane"
           styleClass="root-bg">

    <!-- Lune décorative en haut -->
    <Region fx:id="moonDeco" styleClass="moon" StackPane.alignment="TOP_CENTER">
        <StackPane.margin><Insets top="24"/></StackPane.margin>
    </Region>

    <!-- Lueurs douces dans les coins inférieurs (lanternes invisibles, juste la lumière) -->
    <Region styleClass="lantern-glow" StackPane.alignment="BOTTOM_LEFT">
        <StackPane.margin><Insets bottom="-80" left="-80"/></StackPane.margin>
    </Region>
    <Region styleClass="lantern-glow" StackPane.alignment="BOTTOM_RIGHT">
        <StackPane.margin><Insets bottom="-80" right="-80"/></StackPane.margin>
    </Region>

    <!-- Carte parchemin centrée -->
    <VBox alignment="CENTER" spacing="14" maxWidth="420" maxHeight="-Infinity" styleClass="card">
        <padding><Insets top="36" right="50" bottom="36" left="50"/></padding>

        <Label text="Loup-Garou" styleClass="title-xl"/>
        <Label text="✦  De Thiercelieux  ✦" styleClass="ornament"/>
        <Label text="Entrez dans la légende" styleClass="subtitle"/>

        <Region prefHeight="6"/>

        <TextField fx:id="pseudoField" promptText="Votre nom..." styleClass="input"/>
        <TextField fx:id="emailField"  promptText="Adresse (pour l'inscription)" styleClass="input"/>
        <PasswordField fx:id="passwordField" promptText="Mot de passe secret" styleClass="input"/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Sceau :" styleClass="muted"/>
            <ComboBox fx:id="avatarCombo" prefWidth="110" styleClass="dark-combo"/>
        </HBox>

        <Region prefHeight="6"/>

        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="loginBtn"    text="Se connecter" onAction="#onLogin"    styleClass="btn-primary"/>
            <Button fx:id="registerBtn" text="S'inscrire"   onAction="#onRegister" styleClass="btn-ghost"/>
        </HBox>

        <Label fx:id="errorLabel" styleClass="error"/>
    </VBox>
</StackPane>
