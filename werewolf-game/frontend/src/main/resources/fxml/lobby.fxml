<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.werewolf.controller.LobbyController"
            fx:id="rootPane"
            styleClass="root-bg">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="topbar">
            <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>
            <Label text="🌕 Le Hameau" styleClass="title-l"/>
            <Label text="•" styleClass="ornament"/>
            <Label text="Tableau d'affichage" styleClass="subtitle"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="eloLabel" styleClass="badge badge-ranked"/>
            <Label fx:id="welcomeLabel" styleClass="muted"/>
            <Button fx:id="historyBtn" text="📜 Annales" onAction="#onHistory" styleClass="btn-ghost"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <VBox spacing="12" HBox.hgrow="ALWAYS" styleClass="card">
                <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="⚔  Parties en attente" styleClass="title-m"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="🏆 = classée" styleClass="muted"/>
                </HBox>
                <ListView fx:id="gameList" VBox.vgrow="ALWAYS" prefHeight="420" styleClass="dark-list"/>
                <HBox spacing="10">
                    <Button fx:id="refreshBtn" text="↻ Rafraîchir" onAction="#onRefresh" styleClass="btn-ghost"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="joinBtn"    text="Rejoindre" onAction="#onJoin"    styleClass="btn-primary"/>
                </HBox>
            </VBox>

            <VBox spacing="12" prefWidth="340" styleClass="card">
                <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>
                <Label text="✦  Convoquer un village" styleClass="title-m"/>
                <TextField fx:id="newGameName" promptText="Nom de la partie..." styleClass="input"/>
                <CheckBox  fx:id="rankedCheck" text="🏆 Partie classée (modifie l'ELO)"/>
                <Button fx:id="createBtn" text="⚔ Créer la partie" onAction="#onCreate" styleClass="btn-primary" maxWidth="Infinity"/>
                <Label fx:id="errorLabel" styleClass="error"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Label text="✦  ✦  ✦" styleClass="ornament"/>
                <Label text="Minimum 4 joueurs pour commencer." styleClass="muted"/>
                <Label text="Les loups gagnent s'ils égalent les villageois." styleClass="muted"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
