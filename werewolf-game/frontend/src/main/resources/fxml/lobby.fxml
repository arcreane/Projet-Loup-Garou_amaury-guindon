<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.werewolf.controller.LobbyController"
           fx:id="rootPane"
           styleClass="root-bg">

    <!-- Image atmosphérique en arrière-plan + overlay -->
    <Region fx:id="bgImage" mouseTransparent="true"/>
    <Region styleClass="bg-overlay" mouseTransparent="true"/>

    <BorderPane>
        <!-- ============ Topbar ============ -->
        <top>
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="topbar">
                <padding><Insets top="18" right="28" bottom="18" left="28"/></padding>

                <Label text="🌕" style="-fx-font-size: 22px;"/>
                <VBox>
                    <Label text="LOUP·GAROU" styleClass="title-l"/>
                    <Label text="Lobby" styleClass="muted"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Stats utilisateur -->
                <Label fx:id="eloLabel" styleClass="badge badge-gold"/>
                <Label fx:id="welcomeLabel" styleClass="badge"/>

                <!-- Actions -->
                <Button fx:id="invitationsBtn" text="📨" onAction="#onInvitations" styleClass="btn-icon"/>
                <Button fx:id="profileBtn" text="Profil" onAction="#onProfile" styleClass="btn-ghost"/>
                <Button fx:id="historyBtn" text="Historique" onAction="#onHistory" styleClass="btn-ghost"/>
            </HBox>
        </top>

        <!-- ============ Contenu ============ -->
        <center>
            <HBox spacing="24">
                <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

                <!-- Liste des parties -->
                <VBox spacing="16" HBox.hgrow="ALWAYS" styleClass="card">
                    <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Parties en attente" styleClass="title-m"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="gamesCountLabel" styleClass="muted"/>
                    </HBox>
                    <ListView fx:id="gameList" VBox.vgrow="ALWAYS" prefHeight="500" styleClass="dark-list"/>
                    <HBox spacing="10">
                        <Button fx:id="refreshBtn" text="↻ Actualiser" onAction="#onRefresh" styleClass="btn-ghost"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="joinBtn" text="Rejoindre la partie" onAction="#onJoin" styleClass="btn-primary"/>
                    </HBox>
                </VBox>

                <!-- Créer une partie -->
                <VBox spacing="16" prefWidth="360" maxHeight="-Infinity" alignment="TOP_LEFT" styleClass="card">
                    <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>
                    <Label text="Nouvelle partie" styleClass="title-m"/>
                    <Label text="Crée une partie et invite tes amis." styleClass="muted"/>

                    <VBox spacing="8">
                        <Label text="NOM" styleClass="muted"/>
                        <TextField fx:id="newGameName" promptText="Ma super partie" styleClass="input"/>
                    </VBox>

                    <CheckBox fx:id="rankedCheck" text="Partie classée  (affecte l'ELO)"/>

                    <Button fx:id="createBtn" text="Créer la partie" onAction="#onCreate" styleClass="btn-primary" maxWidth="Infinity"/>

                    <Label fx:id="errorLabel" styleClass="error" wrapText="true"/>

                    <Region prefHeight="8"/>

                    <VBox spacing="6">
                        <Label text="💡  4 joueurs minimum pour démarrer" styleClass="muted"/>
                        <Label text="🐺  Les loups gagnent s'ils égalent les villageois" styleClass="muted"/>
                    </VBox>
                </VBox>
            </HBox>
        </center>
    </BorderPane>
</StackPane>
